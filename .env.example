# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The React web app needs NO keys to run (images load from a public GCS bucket, and
# provider data falls back to bundled JSON if the API is down). The keys below are for
# the data-pipeline scripts (./scripts/) and the logging/providers backend (loma-app/logging-api).

# Google Maps Platform — Places API (New). Used to enrich providers/communities.
# Create at console.cloud.google.com → APIs & Services → Credentials (restrict to Places API).
PLACES_API_KEY=

# Google AI Studio — Gemini API. Used (future) for categorization / review-sentiment.
# Create at aistudio.google.com/apikey . Use model gemini-2.5-flash.
GEMINI_API_KEY=

# PostgreSQL connection string for the logging/providers backend (loma-app/logging-api).
# DigitalOcean managed Postgres. db.py appends the `loma` database + sslmode=require.
POSTGRESQL_CONNECTING_STRING=

# (optional, frontend) Base URL of the logging/providers API. Defaults to http://localhost:8000.
# VITE_LOG_API_URL=http://localhost:8000
